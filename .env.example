# FinOpsWeb — Environment Variables
# Copy this file to .env.local and fill in your values.
# See DECISIONS.md section 17-18 for setup instructions.

# ─── Entra ID / MSAL Authentication ──────────────────────────
# Leave empty to run in anonymous mode (CSV-only, no Azure API access).

# App registration Client ID (from Azure Portal > Entra ID > App registrations)
NEXT_PUBLIC_AZURE_CLIENT_ID=

# Home tenant ID (your organization's Entra ID tenant)
NEXT_PUBLIC_AZURE_TENANT_ID=

# Display name for the home tenant (shown in tenant selector)
NEXT_PUBLIC_AZURE_TENANT_NAME=My Organization

# Client secret for service principal flows (server-side only — never expose to client)
# Required for: Lighthouse cross-tenant access, scheduled report delivery
AZURE_CLIENT_SECRET=

# ─── Additional Tenants (optional) ───────────────────────────
# JSON array of additional tenants for cross-tenant billing access.
# Users can also add tenants via the Settings page.
# NEXT_PUBLIC_AZURE_TENANTS='[{"id":"tenant-id-here","name":"Tenant B","accessMethod":"user"}]'

# ─── Data Source ─────────────────────────────────────────────
# Directory containing FOCUS CSV/Parquet export files.
# Default: ./data/exports
# FOCUS_EXPORTS_DIR=./data/exports

# Maximum rows to parse from CSV/Parquet files (across all files).
# Default: 500000. Lower this if you're running low on memory.
# FOCUS_MAX_ROWS=500000
